
# OPENAI_API_KEY=sk-xxx # 千问
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_API_KEY=sk-xxxx
OPENAI_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-v4-flash

DEEPSEEK_API_KEY=sk-xxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL_NAME=deepseek-v4-flash

# 向量模型地址：必须和写入 Milvus 时的 embedding 模型一致
# 如果只是替换 Chat 模型，不要随手改 embedding，否则需要全量重建向量库
# 注意：DeepSeek 官方 API 目前没有 embeddings 端点，不能用 https://api.deepseek.com 作为 EMBEDDINGS_URL
# 只要配置 EMBEDDINGS_URL / EMBEDDINGS_BASE_URL，就必须配置 EMBEDDINGS_API_KEY
# 模型配置 - 千问
EMBEDDINGS_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDINGS_MODEL_NAME=text-embedding-v3 # 千问
EMBEDDINGS_API_KEY=sk-xxxx # 千问


# embedding-2 # GLM 向量模型
# EMBEDDINGS_API_KEY=sk-xxxx # GLM
# EMBEDDINGS_BASE_URL=https://open.bigmodel.cn/api/paas/v4/embeddings

# MYSQL 相关配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
